# -----------------------------------------------------------------------------
# PYTHON FILES, CACHES, AND LOGS
# -----------------------------------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Logs and databases
*.log
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS & DEPENDENCIES
# -----------------------------------------------------------------------------

# Virtual environment folders (the 'venv' folder from your request)
# Include common variations like 'env' and platform-specific names
venv/
env/
.venv/
.env/
.tox/

# Specific files generated by package managers
# PIP
pip-log.txt
pip-delete-this-directory.txt

# Conda
.conda/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# SENSITIVE DATA & CONFIGURATION (Your Request: .env)
# -----------------------------------------------------------------------------

# Environment variables and configuration files that should NOT be committed
# This is crucial for keeping API keys and secrets safe!
.env
.flaskenv
config.local.py
settings.local.py

# -----------------------------------------------------------------------------
# DISTRIBUTION / PACKAGING
# -----------------------------------------------------------------------------
# Files created when preparing your project for distribution

build/
dist/
develop-eggs/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# IDE and EDITOR FILES
# -----------------------------------------------------------------------------

# VS Code
.vscode/

# PyCharm/IntelliJ
.idea/

# Jupyter Notebook (checkpoints)
.ipynb_checkpoints/